# =============================================================================
# WorkflowNet — Environment Variables
# =============================================================================
# Copia este archivo a .env y completa los valores.
# .env esta en .gitignore — NUNCA subas credenciales al repositorio.

# --- MongoDB ---
MONGO_ROOT_USER=CHANGE_ME
MONGO_ROOT_PASSWORD=CHANGE_ME
MONGO_DATABASE=workflow-spring
MONGODB_URI=mongodb://CHANGE_ME:CHANGE_ME@localhost:27017/workflow-spring?authSource=admin
# --- GitHub OAuth ---
# Configurar en GitHub: Settings → Developer settings → OAuth Apps → New OAuth App
# 1. Application name: "WorkflowNet"
# 2. Homepage URL: http://localhost:4200
# 3. Authorization callback URL: http://localhost:8080/api/auth/github/callback
GITHUB_CLIENT_ID=CHANGE_ME
GITHUB_CLIENT_SECRET=CHANGE_ME
# Desarrollo: http://localhost:8080/api/auth/github/callback
# Produccion: https://api.yourdomain.com/api/auth/github/callback
GITHUB_REDIRECT_URI=http://localhost:8080/api/auth/github/callback

# --- App URLs ---
APP_FRONTEND_URL=http://localhost:4200

# --- JWT / JWS ---
# Generar con: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_MIN_64_CHARS__________________________________________________

# --- SMTP (Email) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME@gmail.com
MAIL_PASSWORD=CHANGE_ME
MAIL_SMTP_AUTH=true
MAIL_STARTTLS_ENABLE=true

# --- Cloudflare DNS Edit Zone ---
# Cloudflare API Token - REEMPLAZA con tu token real
# Pasos para crear token en cloudflare.com:
# 1. Ir a https://dash.cloudflare.com/profile/api-tokens
# 2. "Create Token" -> "Edit zone DNS"
# 3. Permisos: Zone:DNS:Edit
# 4. Recursos: Include -> Specific zone -> yourdomain.com
# 5. Crear y copiar el token aqui
CF_DNS_API_TOKEN=CHANGE_ME

# --- Traefik ---
# Email para Let's Encrypt (certificados TLS automaticos)
ACME_EMAIL=admin@yourdomain.com
# Credenciales para el dashboard de Traefik (Formato: usuario:hash)
# Para generar el hash:
#   - Con contenedor (Recomendado): docker run --rm httpd:alpine htpasswd -nb usuario contraseña
#   - Online: Buscar "Htpasswd Generator" (usar algoritmo MD5/apr1)
# IMPORTANTE: Debes duplicar los signos '$' en el hash resultante (ej. '$apr1$' -> '$$apr1$$') para evitar problemas de escape en docker-compose.
TRAEFIK_PASS_HASH=CHANGE_ME

# --- Domain Routing ---
# Define los dominios publicos que apuntaran a los servicios a traves de Traefik.
# Asegurate de configurar los registros DNS (A o CNAME) correspondientes en Cloudflare.
FRONTEND_DOMAIN=app.yourdomain.com
BACKEND_DOMAIN=api.yourdomain.com

# --- Flow Settings ---
FLOW_GRACE_PERIOD_DAYS=3
DOCUMENT_MAX_SIZE=2097152
DOCUMENT_MAX_COUNT=5

# --- Swagger / OpenAPI ---
# Habilitar/deshabilitar UI de Swagger en /swagger-ui.html
# En produccion, deshabilitar por seguridad: SPRINGDOC_ENABLED=false
SPRINGDOC_ENABLED=true

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# --- Logging ---
# Niveles: ERROR, WARN, INFO, DEBUG, TRACE
LOG_LEVEL=INFO
LOG_LEVEL_ROOT=WARN
LOG_LEVEL_SPRING=WARN
LOG_LEVEL_SECURITY=WARN
LOG_LEVEL_KAFKA=ERROR
