# ===========================================
# Workflow Net - Environment Configuration
# ===========================================

# ---- Server ----
SERVER_PORT=8080

# ---- MongoDB ----
MONGODB_URI=mongodb://workflownet:changeme@localhost:27017/workflow-net?authSource=admin

# ---- Kafka ----
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ---- Mail (SMTP) ----
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=noreply@example.com
MAIL_PASSWORD=changeme
MAIL_SMTP_AUTH=true
MAIL_STARTTLS_ENABLE=true

# ---- GitHub OAuth ----
# Create a GitHub OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:4200/api/auth/github/callback

# ---- JWT / JWS ----
# Generate with: openssl rand -base64 64
JWT_SECRET=change-this-to-a-long-random-base64-secret-key

# ---- Document Settings ----
DOCUMENT_MAX_SIZE=2097152
DOCUMENT_MAX_COUNT=5
DOCUMENT_TEMP_STORAGE=./temp-documents

# ---- Flow Settings ----
FLOW_GRACE_PERIOD_DAYS=3
DEADLINE_CHECK_CRON=0 0 2 * * ?

# ---- Email Retry ----
EMAIL_RETRY_MAX=5

# ---- Admin Credentials ----
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:4200

# ---- API URL (for OpenAPI docs) ----
API_URL=http://localhost:8080

# ---- Docker ----
MONGO_ROOT_USER=workflownet
MONGO_ROOT_PASSWORD=changeme
MONGO_DATABASE=workflow-net

# ---- Grafana ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# ---- Logging ----
LOG_LEVEL=DEBUG
