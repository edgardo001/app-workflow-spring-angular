#!/usr/bin/env bash
# Hook pre-commit: bloquea commits directos en main/master
# Usa ramas de desarrollo y Pull Requests para todos los cambios.

protected_branches="main master"
current_branch=$(git symbolic-ref --short HEAD 2>/dev/null)

for branch in $protected_branches; do
  if [ "$current_branch" = "$branch" ]; then
    echo "============================================="
    echo "  HOOK PRE-COMMIT BLOQUEADO"
    echo "  Archivo: .git/hooks/pre-commit"
    echo "============================================="
    echo ""
    echo "No se permiten commits directos en '$branch'."
    echo "Crea una rama de desarrollo y usa un Pull Request."
    echo ""
    echo "  git checkout -b feat/mi-nueva-funcionalidad"
    echo "  # realizar cambios, agregar y commitear"
    echo "  git push -u origin feat/mi-nueva-funcionalidad"
    echo "  gh pr create"
    echo ""
    exit 1
  fi
done
